<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Appointment Booking</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        .welcome-text {
            text-align: center;
            margin-top: 20px;
            margin-bottom: 30px;
            font-weight: bold;
            color: #333;
        }

        .navbar-brand {
            font-weight: bold;
            font-size: 20px;
        }
    </style>
</head>

<body>

    <!-- 🔝 NAVBAR -->
    <header>
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow">
        <div class="container-fluid">

            <a class="navbar-brand" asp-controller="Appointment" asp-action="Index">
                Appointment Booking
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse justify-content-end" id="navbarContent">
                <ul class="navbar-nav align-items-center">

                    @if (Context.Session.GetString("Email") == null)
                    {
                        <li class="nav-item me-2">
                            <a class="btn btn-light text-primary fw-bold"
                               asp-controller="Auth" asp-action="Login">
                                Login
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="btn btn-outline-light fw-bold"
                               asp-controller="Auth" asp-action="Signup">
                                Signup
                            </a>
                        </li>
                    }
                    else
                    {
                        <!-- <li class="nav-item me-2">
                            <span class="text-white fw-bold">
                                @Context.Session.GetString("Email")
                            </span>
                        </li> -->

                        <li class="nav-item">
                            <a class="btn btn-danger fw-bold"
                               asp-controller="Auth" asp-action="Logout">
                                Logout
                            </a>
                        </li>
                    }

                </ul>
            </div>
        </div>
    </nav>
</header>

    <!-- 🔥 WELCOME TEXT -->
    <div class="container">
        <h1 class="welcome-text">Welcome to Appointment Booking</h1>
    </div>

    <!-- 📄 MAIN CONTENT -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- 🔻 FOOTER -->
    <!-- <footer class="border-top footer text-muted mt-4">
        <div class="container text-center">
            &copy; 2026 - Appointment Booking
        </div>
    </footer> -->

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required:false)

</body>
</html>