@model DAL.Models.Admin
@{
    Layout = null;
}

@{
    ViewData["Title"] = "Signup";
}

<style>
    body {
        background: linear-gradient(135deg, #667eea, #764ba2);
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        font-family: Arial, sans-serif;
    }

    .signup-card {
        background: white;
        padding: 30px;
        border-radius: 12px;
        width: 350px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.2);
        text-align: center;
    }

    .signup-card h2 {
        margin-bottom: 20px;
        color: #333;
    }

    .form-control {
        width: 100%;
        padding: 10px;
        margin: 10px 0;
        border-radius: 6px;
        border: 1px solid #ccc;
    }

    .btn-signup {
        width: 100%;
        padding: 10px;
        background: #667eea;
        color: white;
        border: none;
        border-radius: 6px;
        font-weight: bold;
        cursor: pointer;
    }

    .btn-signup:hover {
        background: #5a67d8;
    }

    .links {
        margin-top: 15px;
        font-size: 14px;
    }

    .links a {
        text-decoration: none;
        color: #667eea;
    }

    .text-danger {
        font-size: 13px;
        display: block;
        text-align: left;
    }
</style>

<div class="signup-card">
    <h2>Create Account</h2>

    <form method="post" autocomplete="off">

        <input asp-for="Email" class="form-control" placeholder="Enter Email" />
        <span asp-validation-for="Email" class="text-danger"></span>

        <input asp-for="Username" class="form-control" placeholder="Enter Username" />
        <span asp-validation-for="Username" class="text-danger"></span>

        <input asp-for="Password" type="password" class="form-control" placeholder="Enter Password" />
        <span asp-validation-for="Password" class="text-danger"></span>

        <button type="submit" class="btn-signup">Signup</button>

    </form>

    <div class="links">
        <a asp-action="Login">Already have an account? Login</a>
    </div>
</div>