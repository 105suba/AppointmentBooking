@{
    Layout = null;
}

<style>
    body {
        background: linear-gradient(135deg, #667eea, #764ba2);
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
        font-family: Arial;
    }

    .card {
        background: white;
        padding: 30px;
        border-radius: 12px;
        width: 400px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.2);
    }

    input, select {
        width: 100%;
        margin-bottom: 15px;
        padding: 10px;
    }

    button {
        width: 100%;
        padding: 10px;
        background: #667eea;
        color: white;
        border: none;
        border-radius: 6px;
    }
</style>

<div class="card">
    <h3 style="text-align:center;">Search Appointments</h3>

    <form asp-action="Search" method="post">

        <input type="text" name="searchTerm" placeholder="Name or Email" />

        <input type="date" name="date" />

        <select name="status" asp-items="ViewBag.StatusList">
            <option value="">All Status</option>
        </select>

        <button type="submit">Search</button>

    </form>
</div>